<IfModule mod_rewrite.c>
  RewriteEngine On

  # ==========================================
  # 1. FORCER LE HTTPS (Optimisé OVH)
  # ==========================================
  # Vérifie si le HTTPS est désactivé ou si le reverse proxy OVH n'est pas en HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ==========================================
  # 2. REDIRECTION 403 VERS ROUTE ANGULAR
  # ==========================================
  # Quand Apache génère une 403 (ex: Options -Indexes), il appelle /.tyro-403
  # Ce RewriteCond le détecte et redirige le navigateur vers /403 du domaine courant
  RewriteCond %{ENV:REDIRECT_STATUS} =403
  RewriteRule ^ https://%{HTTP_HOST}/403 [R=302,L]

  # ==========================================
  # 3. EXCLUSION DE DOSSIERS SPÉCIFIQUES
  # ==========================================
  # Remplace ces chemins par les dossiers à laisser en comportement natif Apache
  # Retire ces lignes si tu n'as pas de dossiers à exclure sur un site spécifique
  # RewriteCond %{REQUEST_URI} !^/dossier_a_exclure_1/
  # RewriteCond %{REQUEST_URI} !^/dossier_a_exclure_2/

  # ==========================================
  # 4. ROUTAGE ANGULAR
  # ==========================================
  # Si le chemin demandé correspond à un fichier existant (-f) ou un dossier existant (-d)
  # (Cela permet à tes assets, scripts, et styles de se charger normalement)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sinon, on renvoie tout le reste vers le point d'entrée d'Angular
  # Si ton site n'est pas à la racine, modifie "/index.html" en "/ton-sous-dossier/index.html"
  RewriteRule ^ /index.html [L]
</IfModule>

# ==========================================
# 5. SÉCURITÉ ET FALLBACK (404 & 403)
# ==========================================
# Désactiver le listing des répertoires (génère une erreur 403 si on tente de lister un dossier)
Options -Indexes

# 404 → Angular gère via la route **
# 403 → /.tyro-403 déclenche le RewriteCond REDIRECT_STATUS=403 ci-dessus
#        qui redirige vers https://[domaine-courant]/403 (route Angular TyroUiForbidden)
ErrorDocument 404 /index.html
ErrorDocument 403 /.tyro-403
